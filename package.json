{
  "name": "menu-ocr",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "dev:api": "npm run dev --workspace=api",
    "build": "npm run build --workspace=web",
    "build:api": "npm run build --workspace=api",
    "deploy": "npm run deploy --workspace=api",
    "test": "npm run test --workspace=web && npm run test --workspace=api",
    "test:e2e": "npm run test:e2e --workspace=web",
    "test:integration": "npm run test:integration --workspace=api"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}